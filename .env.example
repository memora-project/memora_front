# .env 파일 예시
#
# 백엔드 API base URL.
# - Android 에뮬레이터: http://10.0.2.2:8080/api/v1
# - iOS 시뮬레이터:    http://localhost:8080/api/v1
# - 실기기:           http://<PC_와이파이_IP>:8080/api/v1
#
# OpenRouter API 키는 더 이상 앱에 두지 않습니다 (보안).
# AI 호출은 백엔드를 통해서만 일어납니다. 백엔드의 .env에 OPENROUTER_API_KEY를 두세요.
API_BASE_URL=http://10.0.2.2:8080/api/v1

# .env 파일 예시
#
# 백엔드 API base URL.
# - Android 에뮬레이터: http://10.0.2.2:8080/api/v1
# - iOS 시뮬레이터:    http://localhost:8080/api/v1
# - 실기기:           http://<PC_와이파이_IP>:8080/api/v1
#
# OpenRouter API 키는 더 이상 앱에 두지 않습니다 (보안).
# AI 호출은 백엔드를 통해서만 일어납니다. 백엔드의 .env에 OPENROUTER_API_KEY를 두세요.
API_BASE_URL=http://10.0.2.2:8080/api/v1

# 카카오 로그인 — REST API 키 (공개 OAuth client_id 역할이라 앱 번들에 포함돼도 안전).
# 카카오 콘솔(https://developers.kakao.com)의 [내 애플리케이션 > 앱 키 > REST API 키].
# 토큰 교환(client_secret 필요)은 백엔드가 수행하므로 앱에는 절대 client_secret을 넣지 않는다.
KAKAO_REST_API_KEY=카카오_REST_API_키
# 카카오 콘솔에 등록된 OAuth Redirect URI. WebView가 이 URL로 redirect되면 가로채서 code를 추출함.
# 실제로 그 URL이 살아있을 필요는 없음 — 등록만 되어 있으면 됨.
KAKAO_REDIRECT_URI=http://localhost:5173/oauth/kakao

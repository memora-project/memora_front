# .env 파일 예시
OPENROUTER_API_KEY=복사한_키_값_여기에_붙여넣기
API_BASE_URL=http://localhost:8080/api/v1

# 카카오 로그인 — 백엔드 환경변수와 동일한 REST API 키.
# 카카오 콘솔(https://developers.kakao.com)의 [내 애플리케이션 > 앱 키 > REST API 키].
KAKAO_REST_API_KEY=카카오_REST_API_키
# 카카오 콘솔에 등록된 OAuth Redirect URI. WebView가 이 URL로 redirect되면 가로채서 code를 추출함.
# 실제로 그 URL이 살아있을 필요는 없음 — 등록만 되어 있으면 됨.
KAKAO_REDIRECT_URI=http://localhost:5173/oauth/kakao
